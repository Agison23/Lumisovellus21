{
  "name": "backend",
  "version": "1.0.0",
  "description": "Lumisovellus unified backend API",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:full": "concurrently \"tsx watch src/server.ts\" \"tsx watch --poll src/swagger.ts\"",
    "build": "tsc -p tsconfig.json",
    "build:swagger": "tsx src/swagger.ts",
    "build:swagger:clean": "rm -f swagger-output.json && tsx src/swagger.ts",
    "swagger:watch": "tsx watch src/swagger.ts",
    "start": "node dist/server.js",
    "test": "npm run test:docker",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:db": "dotenv -e .env.test -- vitest",
    "test:db:watch": "dotenv -e .env.test -- vitest --watch",
    "test:migrate": "dotenv -e .env.test -- npx prisma migrate deploy",
    "test:db:setup": "dotenv -e .env.test -- npx prisma db push",
    "test:docker": "docker compose -f docker-compose.test.yml up -d && npm run test:db:setup && npm run test:db && docker compose -f docker-compose.test.yml down",
    "test:keep-db": "node scripts/run-tests.cjs --keep-db",
    "test:unit": "dotenv -e .env.test -- vitest src/test/unit",
    "test:integration": "dotenv -e .env.test -- vitest src/test/integration",
    "test:auth": "dotenv -e .env.test -- vitest src/test/unit/auth.service.test.ts src/test/integration/auth.api.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rm -rf dist",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@repo/shared": "*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.2.2",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/tsconfig": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.12",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/coverage-v8": "^2.1.4",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^10.0.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.4"
  },
  "keywords": [
    "api",
    "backend",
    "express",
    "typescript",
    "prisma"
  ],
  "author": "Mindhive Oy",
  "license": "MIT"
}
