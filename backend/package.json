{
  "name": "NorthStar",
  "version": "1.0.0",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "test": "NODE_ENV=test DB_HOST=mysql DB_PORT=3306 DB_USER=app DB_PASSWORD=app_password DB_NAME=northstar_test NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "test:watch": "jest --watch",
    "swagger": "node -r dotenv/config --loader ts-node/esm app/swagger.ts",
    "build": "npm run swagger && tsc -p tsconfig.build.json",
    "start": "npm run build && node dist/app/index.js",
    "dev": "nodemon --ignore app/docs/**/*.json --watch app --ext ts,js,json --exec \"node --loader ts-node/esm\" app/index.ts",
    "swagger:gen": "node --loader ts-node/esm app/swagger.ts",
    "swagger:watch": "nodemon --legacy-watch --watch app --ext ts,js,json --ignore app/docs/**/*.json --exec \"node --loader ts-node/esm app/swagger.ts\""
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "faker": "^6.6.6",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "nodemon": "^3.1.10",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.6.2",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
