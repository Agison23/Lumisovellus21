{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^dev"]
    },
    "build": {
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"]
    },
    "test": {},
    "lint": { "outputs": [], "dependsOn": ["^lint"] },
    "lint:fix": { "outputs": [], "dependsOn": ["^lint:fix"] },
    "typecheck": { "outputs": [], "dependsOn": ["^typecheck"] },
    "format": { "outputs": [] },
    "format:check": { "outputs": [] }
  }
}
