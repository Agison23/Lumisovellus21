{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["^dev"]
    },
    "build": {
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"]
    },
    "e2e": {
      "passThroughEnv": ["PLAYWRIGHT_*"]
    },
   "test": {
      "dependsOn": ["transit"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "lint": { "outputs": [], "dependsOn": ["^lint"] },
    "typecheck": { "outputs": [], "dependsOn": ["^typecheck"] }
  }
}