{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {"cache": false, "persistent": true, "dependsOn": ["^dev"]},

    "openapi:emit": {},
    "openapi:client:web": {},
    "openapi:client:mobile": {},
    "openapi:check": { "dependsOn": ["openapi:client:web", "openapi:client:mobile"], "outputs": [] },

    "lint": { "outputs": [], "dependsOn": ["^lint"] },
    "lint:heavy": { "outputs": [], "dependsOn": ["^lint:heavy"] },

    "typecheck": { "outputs": [], "dependsOn": ["^typecheck"] },

    "test": {},

    "build": {
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build", "^openapi:check", "^typecheck", "^lint", "^test"]
    }
  }
}